# Copy this to .env and fill in your values

# Postgres
POSTGRES_PASSWORD=changeme_use_strong_password

# API security
API_KEY=generate-a-random-string-here

# Baileys tuning (adjust based on your account's risk tolerance)
# Lower = safer but slower
CHECK_DELAY_MS=500          # ms between bulk batches
RATE_LIMIT_POINTS=10        # requests per...
RATE_LIMIT_DURATION=1       # ...this many seconds

# Worker scaling
WORKER_CONCURRENCY=3        # parallel job processors
BATCH_SIZE=25               # numbers per Baileys call (max 50)
MAX_RETRIES=3
